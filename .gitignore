.env
.streamlit/credentials.toml
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.DS_Store
# LibreOffice Calc lock files (do not commit)
**/.~lock.*
.uv/
uv.lock.bak

# BACI CSVs are large — keep data/baci/ in repo via .gitkeep only
data/baci/*
!data/baci/.gitkeep

# CEPI CSVs are large — same pattern
data/cepi/*
!data/cepi/.gitkeep

# JODI / USGS manual downloads — keep dirs, ignore blobs
data/jodi/*
!data/jodi/.gitkeep
data/usgs/*
!data/usgs/.gitkeep
