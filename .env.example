# Copy to .env and fill in values. Never commit .env.
#
# Supabase → Project Settings → API
#
# Pullers/loaders: utils.supabase_client.get_client() uses, in order:
#   SUPABASE_SERVICE_ROLE_KEY, SUPABASE_SECRET_KEY, or legacy SUPABASE_KEY
# Read-only Streamlit: get_read_client() uses SUPABASE_ANON_PUBLIC_KEY or SUPABASE_PUBLISHABLE_KEY

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ANON_PUBLIC_KEY=

# pull_eia.py — https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# pull_usda_psd.py — https://api.fas.usda.gov
USDA_FAS_API_KEY=

# pull_faostat.py — optional local paths for bulk ZIPs (skip HTTP fetch)
# FAOSTAT_ZIP_PATH=
# FAOSTAT_FBS_ZIP_PATH=
# Fertilizer data: faostat package API (avoids CloudFront-blocked bulk URLs). v2 requires auth:
# FAOSTAT_API_TOKEN=
# Or: FAOSTAT_USERNAME= / FAOSTAT_PASSWORD=
# Optional: FAOSTAT_FERTILIZER_API_CODE=RFB (default in code) or RFN (nutrients)
# Optional: FAOSTAT_API_PAGE_LIMIT=50000
# Optional: FAOSTAT_API_AREA_CHUNK=40 (FAO area codes per request)
# Optional: FAOSTAT_API_SLEEP_SEC=0.2 (pause between area chunks)
# Optional: FAOSTAT_API_AREAS=2,4,9 (comma-separated FAO codes; omit = all countries)

# UN Comtrade — https://comtradeplus.un.org/
COMTRADE_PRIMARY_KEY=
COMTRADE_SECONDARY_KEY=
